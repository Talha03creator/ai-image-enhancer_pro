rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The user's UID
    //   - email: string (required) - The user's email
    //   - displayName: string (optional) - The user's name
    //   - photoURL: string (optional) - The user's profile picture
    //   - createdAt: timestamp (required) - When the user was created
    //
    // Collection: history
    // Document ID: {historyId} (Auto-generated)
    // Fields:
    //   - id: string (required) - Unique ID
    //   - uid: string (required) - The owner's UID
    //   - name: string (required) - Original file name
    //   - original: string (required) - URL to original
    //   - enhanced: string (required) - URL to enhanced
    //   - mode: string (required) - Enhancement mode
    //   - timestamp: number (required) - Unix timestamp
    //   - type: string (required) - 'image' or 'video'
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "moyih50210@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidEmail(email) {
      return email is string && email.size() > 5 && email.size() < 100 && email.matches("^.+@.+\\..+$");
    }

    function isValidUrl(url) {
      return url is string && url.size() < 1048576 && (
        url.matches("^https://.*") || 
        url.matches("^http://.*") || 
        url.matches("^data:.*") || 
        url.matches("^blob:.*") ||
        url.matches("^/outputs/.*")
      );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             isValidEmail(data.email) &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() < 100)) &&
             (data.photoURL == null || isValidUrl(data.photoURL)) &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidHistoryItem(data) {
      return hasRequiredFields(['id', 'uid', 'name', 'original', 'enhanced', 'mode', 'timestamp', 'type']) &&
             data.uid == request.auth.uid &&
             data.id is string && data.id.size() < 100 &&
             data.name is string && data.name.size() < 255 &&
             isValidUrl(data.original) &&
             isValidUrl(data.enhanced) &&
             data.mode is string && data.mode.size() < 50 &&
             data.timestamp is number &&
             data.type == 'image';
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid &&
                      (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /history/{historyId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidHistoryItem(request.resource.data);
      allow update: if isDocOwner() && isValidHistoryItem(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isDocOwner() || isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
